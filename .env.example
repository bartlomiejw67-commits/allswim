# Skopiuj ten plik do .env.local i uzupełnij wartości.
# .env.local NIE trafia do repozytorium (zawiera sekrety).

# Publiczny adres wdrożenia Convex (frontend łączy się z tym URL).
# Otrzymasz go automatycznie po uruchomieniu `npx convex dev`
# (Convex dopisze też CONVEX_DEPLOYMENT do .env.local).
NEXT_PUBLIC_CONVEX_URL=https://twoj-deployment.convex.cloud
